# Dependencies
node_modules/

# Environment variables (contains secrets!)
.env

# Personal configuration (contains tokens/user IDs)
config.json
starcommander-config.json

# Logs
*.log
*.log.*
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
out/
*.exe
# Note: build/ is NOT ignored — electron-app/build/appx/ holds the
# Microsoft Store tile PNGs (read by electron-builder at .appx build time).

# Misc
*.bak
*.tmp

# Local-only files (not part of Star Commander)
rehydratation.html
StarCommander.code-workspace
